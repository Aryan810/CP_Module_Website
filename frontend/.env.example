# Example Environment Variables
# Copy this file to .env.development or .env.production and update values

# API Base URL - use relative path for production, full URL for development
VITE_API_BASE_URL=http://localhost:3001/api

# App Title
VITE_APP_TITLE=CP-Hub

# Firebase Web SDK config (get these from Firebase console → Project settings → Your apps)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=